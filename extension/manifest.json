{
  "manifest_version": 3,
  "name": "BetterSparx",
  "description": "BetterSparx by ChurroAI",
  "version": "1.0",
  "icons": {
    "128": "icon.png"
  },
  "action": {
    "default_popup": "ui/popup.html"
  },
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "*://*.sparx-learning.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["*://*.sparx-learning.com/*"],
      "js": ["darkmode/main.js"]
    }
  ]
}